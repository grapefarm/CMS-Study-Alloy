@model PageViewModel<PromotionPage>

@{ Layout = "~/Views/Shared/Layouts/_LeftNavigation.cshtml"; }

<article class="promotion-page content">
    <h1 @Html.EditAttributes(x => x.CurrentPage.PageName)>@Model.CurrentPage.PageName</h1>

    <div class="lead" @Html.EditAttributes(x => x.CurrentPage.Introduction)>
        @Html.PropertyFor(x => x.CurrentPage.Introduction)
    </div>

    @Html.PropertyFor(x => x.CurrentPage.PromotionItems, new { CssClass = "row" })
</article>
